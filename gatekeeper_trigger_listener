# gatekeeper_trigger_listener - OpenWrt init script for gatekeeper event listener
#
# This init script manages the gatekeeper_trigger.sh service as a procd-managed daemon.
# It ensures continuous monitoring of ubus events from dnsmasq and trigger appropriate
# gatekeeper responses for new network device discoveries.
#
# Service Configuration:
# - START=95: Runs late in boot process to ensure network and ubus services are ready
# - USE_PROCD=1: Uses procd daemon management for automatic restart and logging
# - respawn: Automatically restarts service on failure (enhances reliability)
#
# Integration Points:
# - Launches gatekeeper_trigger.sh as a persistent background process
# - Captures stdout/stderr for logread integration
# - Registers with OpenWrt standard init.d service framework
#
# Maintenance:
# After placing this file in /etc/init.d/:
#   chmod +x /etc/init.d/gatekeeper_trigger_listener
#   /etc/init.d/gatekeeper_trigger_listener enable
#   /etc/init.d/gatekeeper_trigger_listener start
#
# To view logs: logread -f | grep gatekeeper_trigger_listener
#
# Restart service: /etc/init.d/gatekeeper_trigger_listener restart
#
# Security:
# - Service runs with standard user privileges (no elevated permissions needed)
# - Procd handles lifecycle management and crash recovery
# - Logs are available through standard OpenWrt logging system

# OpenWrt init system parameters
USE_PROCD=1           # Enable procd daemon management
START=95              # Start position in boot sequence (late boot)

# Main service start function called by procd
start_service() {
    # Defensive cleanup — see tg_gatekeeper for the procd ghost-instance race.
    # The trigger listener is less prone to it (ubus monitor interrupts sh from
    # read(2) promptly), but symmetric hardening is cheap and prevents a
    # leaked listener from double-firing events into gatekeeper.sh.
    killall -KILL gatekeeper_trigger.sh 2>/dev/null
    sleep 1

    procd_open_instance "gatekeeper_trigger_listener"
    # gatekeeper_trigger.sh has a proper #!/bin/sh shebang and is +x — invoke
    # directly instead of through an extra /bin/sh wrapper.
    procd_set_param command /usr/bin/gatekeeper_trigger.sh
    # Default term_timeout (~5s) is plenty since ubus monitor's read breaks
    # out of blocking read(2) on SIGTERM; raise slightly for safety margin.
    procd_set_param term_timeout 10
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

# Reap any untracked gatekeeper_trigger.sh instances procd may have lost
# during a past crash/restart race.
stop_service() {
    killall -TERM gatekeeper_trigger.sh 2>/dev/null
    sleep 2
    killall -KILL gatekeeper_trigger.sh 2>/dev/null
    return 0
}

# Service enablement and control commands (for documentation):
# chmod +x /etc/init.d/gatekeeper_trigger_listener
# /etc/init.d/gatekeeper_trigger_listener enable
# /etc/init.d/gatekeeper_trigger_listener start
# /etc/init.d/gatekeeper_trigger_listener stop
# /etc/init.d/gatekeeper_trigger_listener restart
